---
import RealTimeHeader from "./RealTimeHeader.astro";

export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const navItems = [
  { path: "/", label: "DASHBOARD", icon: "●" },
  { path: "/last", label: "ACTIVITIES", icon: "◐" },
  { path: "/map", label: "ROUTES", icon: "◑" },
  { path: "/hevy", label: "WORKOUTS", icon: "◑" },
  { path: "/health", label: "HEALTH", icon: "◑" },
  { path: "/record", label: "RECORDS", icon: "◑" },
  { path: "/about", label: "ABOUT", icon: "◑" },
];
---

<!-- Real-time metrics header -->
<RealTimeHeader />

<nav class="browser-tabs-nav">
  <div class="tabs-container">
    {
      navItems.map(item => (
        <a
          href={item.path}
          class={`browser-tab ${currentPath === item.path ? "active" : ""}`}
        >
          <span class="tab-icon">{item.icon}</span>
          <span class="tab-label">{item.label}</span>
          <span class="tab-close">×</span>
        </a>
      ))
    }

    <!-- New Tab Button -->
    <button class="new-tab-btn">
      <span class="text-green-400">+</span>
    </button>
  </div>

</nav>

<style>
  .browser-tabs-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(180deg, rgba(0, 20, 0, 0.95) 0%, rgba(0, 10, 0, 0.9) 100%);
    border-bottom: 2px solid rgba(0, 255, 0, 0.4);
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .browser-tabs-nav::-webkit-scrollbar {
    display: none;
  }

  .tabs-container {
    display: flex;
    align-items: stretch;
    gap: 1px;
    flex: 1;
    min-width: 0;
  }

  .browser-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(0, 20, 0, 0.6);
    border: none;
    border-right: 1px solid rgba(0, 255, 0, 0.15);
    color: rgba(0, 255, 0, 0.6);
    text-decoration: none;
    font-size: 0.7rem;
    font-family: "Courier New", monospace;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.15s ease;
    position: relative;
    white-space: nowrap;
    cursor: pointer;
  }

  .browser-tab:hover {
    background: rgba(0, 255, 0, 0.15);
    color: rgba(0, 255, 0, 0.9);
  }

  .browser-tab.active {
    background: linear-gradient(180deg, rgba(0, 255, 0, 0.2) 0%, rgba(0, 255, 0, 0.1) 100%);
    color: #00ff00;
    box-shadow: inset 0 -2px 0 #00ff00;
  }

  .browser-tab.active::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(0, 255, 0, 0.5);
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
  }

  .tab-icon {
    font-size: 10px;
    color: #00ff00;
    animation: pulse 2s ease-in-out infinite;
  }

  .tab-label {
    flex: 1;
  }

  .tab-close {
    opacity: 0;
    font-size: 14px;
    color: rgba(255, 68, 68, 0.8);
    transition: opacity 0.15s ease;
  }

  .browser-tab:hover .tab-close {
    opacity: 0.6;
  }

  .tab-close:hover {
    opacity: 1 !important;
    color: #ff4444;
  }

  .new-tab-btn {
    padding: 10px 14px;
    background: transparent;
    border: none;
    border-left: 1px solid rgba(0, 255, 0, 0.15);
    color: rgba(0, 255, 0, 0.5);
    cursor: pointer;
    transition: all 0.15s ease;
    font-size: 16px;
    font-weight: bold;
  }

  .new-tab-btn:hover {
    background: rgba(0, 255, 0, 0.15);
    color: #00ff00;
  }

  .browser-controls {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 0 8px;
    border-left: 1px solid rgba(0, 255, 0, 0.15);
  }

  .control-btn {
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    color: rgba(0, 255, 0, 0.5);
    font-size: 14px;
    cursor: pointer;
    transition: all 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .control-btn:hover {
    background: rgba(0, 255, 0, 0.15);
    color: #00ff00;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .browser-tab {
      padding: 8px 12px;
      font-size: 0.65rem;
    }

    .tab-label {
      display: none;
    }

    .browser-tab {
      padding: 8px 10px;
    }

    .browser-controls {
      padding: 0 4px;
    }
  }

  @media (max-width: 480px) {
    .browser-controls {
      display: none;
    }

    .new-tab-btn {
      padding: 8px 10px;
    }
  }
</style>
