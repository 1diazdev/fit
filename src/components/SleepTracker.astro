---
import type { SleepData } from "@/services/googleFitService";

export interface Props {
  sleepData: SleepData;
  daysToShow?: number;
}

const { sleepData, daysToShow = 7 } = Astro.props;

// Get recent sleep data (last N days)
const recentSleep = Object.entries(sleepData)
  .sort((a, b) => new Date(b[0]).getTime() - new Date(a[0]).getTime())
  .slice(0, daysToShow)
  .reverse();

// Calculate average sleep
const avgTotalMinutes =
  recentSleep.length > 0
    ? recentSleep.reduce((sum, [_, data]) => sum + data.totalMinutes, 0) /
      recentSleep.length
    : 0;

const avgHours = Math.floor(avgTotalMinutes / 60);
const avgMinutes = Math.round(avgTotalMinutes % 60);

// Sleep score color based on score
function getScoreColor(score: number): string {
  if (score >= 80) return "text-green-300";
  if (score >= 60) return "text-yellow-400";
  return "text-red-400";
}

// Sleep duration color
function getDurationColor(minutes: number): string {
  if (minutes >= 420 && minutes <= 540) return "text-green-300"; // 7-9 hours
  if (minutes >= 360) return "text-yellow-400"; // 6-7 hours
  return "text-red-400"; // < 6 hours
}
---

<div class="sleep-tracker-container">
  <div class="sleep-tracker-wrapper">
    <!-- Header with average -->
    <div class="sleep-header">
      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="stat-box">
          <div class="text-green-400/60 text-xs font-mono mb-1">AVG_SLEEP:</div>
          <div class="text-green-300 text-2xl font-mono font-bold">
            {avgHours}h {avgMinutes}m
          </div>
        </div>
        <div class="stat-box">
          <div class="text-green-400/60 text-xs font-mono mb-1">
            TRACKED_NIGHTS:
          </div>
          <div class="text-green-300 text-2xl font-mono font-bold">
            {recentSleep.length}
          </div>
        </div>
      </div>
    </div>

    <!-- Sleep timeline -->
    <div class="sleep-timeline">
      {
        recentSleep.length > 0 ? (
          recentSleep.map(([date, data]) => {
            const totalHours = Math.floor(data.totalMinutes / 60);
            const totalMins = Math.round(data.totalMinutes % 60);
            const deepPercent = (data.deepMinutes / data.totalMinutes) * 100;
            const lightPercent = (data.lightMinutes / data.totalMinutes) * 100;
            const remPercent = (data.remMinutes / data.totalMinutes) * 100;

            return (
              <div class="sleep-day group">
                <div class="sleep-date">
                  <span class="text-green-400/70 text-xs font-mono">
                    {new Date(date).toLocaleDateString("en-US", {
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                </div>

                <div class="sleep-bar-container">
                  {/* Stacked bar chart */}
                  <div class="sleep-bar">
                    {/* Deep sleep */}
                    <div
                      class="sleep-segment deep-sleep"
                      style={`width: ${deepPercent}%`}
                      title={`Deep: ${Math.round(data.deepMinutes)}m`}
                    />
                    {/* Light sleep */}
                    <div
                      class="sleep-segment light-sleep"
                      style={`width: ${lightPercent}%`}
                      title={`Light: ${Math.round(data.lightMinutes)}m`}
                    />
                    {/* REM sleep */}
                    <div
                      class="sleep-segment rem-sleep"
                      style={`width: ${remPercent}%`}
                      title={`REM: ${Math.round(data.remMinutes)}m`}
                    />
                  </div>

                  {/* Tooltip on hover */}
                  <div class="sleep-tooltip">
                    <div class="tooltip-content">
                      <div class="text-green-300 font-bold mb-2">
                        {totalHours}h {totalMins}m total
                      </div>
                      <div class="space-y-1 text-xs">
                        <div class="flex justify-between">
                          <span class="text-blue-400">Deep:</span>
                          <span class="text-blue-300">
                            {Math.round(data.deepMinutes)}m
                          </span>
                        </div>
                        <div class="flex justify-between">
                          <span class="text-cyan-400">Light:</span>
                          <span class="text-cyan-300">
                            {Math.round(data.lightMinutes)}m
                          </span>
                        </div>
                        <div class="flex justify-between">
                          <span class="text-purple-400">REM:</span>
                          <span class="text-purple-300">
                            {Math.round(data.remMinutes)}m
                          </span>
                        </div>
                        <div class="border-t border-green-500/30 pt-1 mt-1">
                          <div class="flex justify-between">
                            <span class="text-green-400">Score:</span>
                            <span class={getScoreColor(data.sleepScore)}>
                              {data.sleepScore}/100
                            </span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="sleep-info">
                  <span
                    class={`text-sm font-mono ${getDurationColor(data.totalMinutes)}`}
                  >
                    {totalHours}h{totalMins}m
                  </span>
                  <span
                    class={`text-xs font-mono ml-2 ${getScoreColor(data.sleepScore)}`}
                  >
                    {data.sleepScore}
                  </span>
                </div>
              </div>
            );
          })
        ) : (
          <div class="no-data">
            <div class="text-green-400/60 text-sm font-mono text-center py-8">
              NO_SLEEP_DATA_AVAILABLE
            </div>
          </div>
        )
      }
    </div>

    <!-- Legend -->
    <div class="sleep-legend mt-6">
      <div class="grid grid-cols-3 gap-3 text-xs font-mono">
        <div class="legend-item">
          <div class="legend-color deep-sleep-color"></div>
          <span class="text-blue-300">DEEP</span>
        </div>
        <div class="legend-item">
          <div class="legend-color light-sleep-color"></div>
          <span class="text-cyan-300">LIGHT</span>
        </div>
        <div class="legend-item">
          <div class="legend-color rem-sleep-color"></div>
          <span class="text-purple-300">REM</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .sleep-tracker-container {
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 20, 0, 0.7) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 8px;
    padding: 24px;
    box-shadow:
      0 0 25px rgba(0, 255, 0, 0.2),
      inset 0 0 25px rgba(0, 255, 0, 0.05);
    position: relative;
    overflow: hidden;
  }

  .sleep-tracker-wrapper {
    position: relative;
    z-index: 2;
  }

  .stat-box {
    background: rgba(0, 255, 0, 0.05);
    border: 1px solid rgba(0, 255, 0, 0.1);
    border-radius: 6px;
    padding: 12px;
    text-align: center;
  }

  .sleep-timeline {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(0, 255, 0, 0.2);
    border-radius: 6px;
    padding: 16px;
    min-height: 200px;
  }

  .sleep-day {
    display: grid;
    grid-template-columns: 60px 1fr 80px;
    gap: 12px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid rgba(0, 255, 0, 0.1);
    position: relative;
  }

  .sleep-day:last-child {
    border-bottom: none;
  }

  .sleep-bar-container {
    position: relative;
    height: 32px;
  }

  .sleep-bar {
    display: flex;
    height: 100%;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(0, 255, 0, 0.2);
    transition: all 0.3s ease;
  }

  .group:hover .sleep-bar {
    transform: scaleY(1.1);
    box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
  }

  .sleep-segment {
    height: 100%;
    transition: all 0.3s ease;
  }

  .deep-sleep {
    background: linear-gradient(
      to right,
      rgba(30, 64, 175, 0.8),
      rgba(59, 130, 246, 0.8)
    );
  }

  .light-sleep {
    background: linear-gradient(
      to right,
      rgba(6, 182, 212, 0.6),
      rgba(34, 211, 238, 0.6)
    );
  }

  .rem-sleep {
    background: linear-gradient(
      to right,
      rgba(126, 34, 206, 0.7),
      rgba(168, 85, 247, 0.7)
    );
  }

  .sleep-tooltip {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    z-index: 100;
  }

  .group:hover .sleep-tooltip {
    opacity: 1;
  }

  .tooltip-content {
    background: rgba(0, 0, 0, 0.95);
    border: 1px solid rgba(0, 255, 0, 0.5);
    border-radius: 6px;
    padding: 12px;
    min-width: 150px;
    box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
  }

  .sleep-info {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .sleep-legend {
    padding-top: 16px;
    border-top: 1px solid rgba(0, 255, 0, 0.2);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .legend-color {
    width: 20px;
    height: 12px;
    border-radius: 2px;
    border: 1px solid rgba(0, 255, 0, 0.2);
  }

  .deep-sleep-color {
    background: linear-gradient(
      to right,
      rgba(30, 64, 175, 0.8),
      rgba(59, 130, 246, 0.8)
    );
  }

  .light-sleep-color {
    background: linear-gradient(
      to right,
      rgba(6, 182, 212, 0.6),
      rgba(34, 211, 238, 0.6)
    );
  }

  .rem-sleep-color {
    background: linear-gradient(
      to right,
      rgba(126, 34, 206, 0.7),
      rgba(168, 85, 247, 0.7)
    );
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .sleep-day {
      grid-template-columns: 50px 1fr 70px;
      gap: 8px;
    }

    .sleep-tracker-container {
      padding: 16px;
    }
  }
</style>
