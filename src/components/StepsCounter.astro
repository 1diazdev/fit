---
export interface Props {
  steps: number;
  distance?: number; // meters
  calories?: number;
}

const { steps, distance = 0, calories = 0 } = Astro.props;

// Determine status level based on step count
function getStatusLevel(steps: number): {
  level: string;
  color: string;
  message: string;
} {
  if (steps >= 10000)
    return {
      level: "OPTIMAL",
      color: "text-green-300",
      message: "TARGET_ACHIEVED",
    };
  if (steps >= 7500)
    return {
      level: "GOOD",
      color: "text-green-400",
      message: "ABOVE_AVERAGE",
    };
  if (steps >= 5000)
    return {
      level: "WARNING",
      color: "text-yellow-400",
      message: "BELOW_TARGET",
    };
  return {
    level: "CRITICAL",
    color: "text-red-400",
    message: "INSUFFICIENT_ACTIVITY",
  };
}

const status = getStatusLevel(steps);
---

<div class="steps-count-container">
  <div class="steps-count-wrapper">
    <!-- Matrix-style steps count display -->
    <div class="steps-count-display">
      <div class="count-grid">
        <div class="count-label">
          <span class="text-green-400/60 text-sm font-mono">DAILY_STEPS:</span>
        </div>
        <div class="count-value">
          <span
            class={`text-4xl font-mono font-bold tracking-wider ${status.color}`}
          >
            {(steps || 0).toLocaleString()}
          </span>
        </div>
        <div class="mt-2">
          <span class="text-green-400/60 text-xs font-mono">
            STATUS: <span class={status.color}>{status.level}</span>
          </span>
        </div>
      </div>

      <!-- Matrix rain effect elements -->
      <div class="matrix-rain">
        {
          Array.from({ length: 12 }).map((_, i) => (
            <div
              class={`rain-column rain-column-${i + 1}`}
              style={`animation-delay: ${i * 0.3}s;`}
            >
              {Array.from({ length: 8 }).map((_, j) => (
                <span class="rain-char">{Math.floor(Math.random() * 2)}</span>
              ))}
            </div>
          ))
        }
      </div>
    </div>

    <!-- Status indicators -->
    <div class="steps-status mt-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs">
        <div class="status-block">
          <span class="text-green-400/60">DISTANCE:</span>
          <span class="text-green-300 ml-2">
            {(distance / 1000).toFixed(2)} KM
          </span>
        </div>
        <div class="status-block">
          <span class="text-green-400/60">CALORIES:</span>
          <span class="text-green-300 ml-2">{Math.round(calories)} CAL</span>
        </div>
        <div class="status-block">
          <span class="text-green-400/60">SOURCE:</span>
          <span class="text-green-300 ml-2 flex items-center">
            <div class="w-1 h-1 bg-green-500 rounded-full mr-1 animate-pulse">
            </div>
            GOOGLE_FIT
          </span>
        </div>
      </div>
    </div>

    <!-- Progress bar to 10k steps -->
    <div class="mt-4">
      <div
        class="flex justify-between text-xs font-mono text-green-400/60 mb-1"
      >
        <span>TARGET_PROGRESS:</span>
        <span>{Math.min(Math.round((steps / 10000) * 100), 100)}%</span>
      </div>
      <div
        class="w-full h-2 bg-black/60 border border-green-500/30 rounded-full overflow-hidden"
      >
        <div
          class="h-full bg-gradient-to-r from-green-600 to-green-400 transition-all duration-1000 ease-out"
          style={`width: ${Math.min((steps / 10000) * 100, 100)}%`}
        >
          <div class="w-full h-full animate-pulse bg-green-300/20"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Steps Count Container Styles - Matrix Green Theme */
  .steps-count-container {
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 20, 0, 0.7) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 8px;
    padding: 24px;
    box-shadow:
      0 0 25px rgba(0, 255, 0, 0.2),
      inset 0 0 25px rgba(0, 255, 0, 0.05);
    position: relative;
    overflow: hidden;
  }

  .steps-count-container::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 9px;
    padding: 1px;
    background: linear-gradient(
      45deg,
      rgba(0, 255, 0, 0.4),
      transparent,
      rgba(0, 255, 0, 0.4)
    );
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: xor;
    animation: stepsBorderGlow 3s ease-in-out infinite;
  }

  @keyframes stepsBorderGlow {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.9;
    }
  }

  .steps-count-wrapper {
    position: relative;
    z-index: 2;
  }

  .steps-count-display {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 120px;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(0, 255, 0, 0.2);
    border-radius: 6px;
    overflow: hidden;
  }

  .count-grid {
    text-align: center;
    z-index: 3;
    position: relative;
  }

  .count-value {
    margin-top: 8px;
    text-shadow:
      0 0 10px rgba(0, 255, 0, 0.8),
      0 0 20px rgba(0, 255, 0, 0.5),
      0 0 30px rgba(0, 255, 0, 0.3);
    animation: countPulse 2s ease-in-out infinite;
  }

  @keyframes countPulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }
    50% {
      transform: scale(1.05);
      opacity: 1;
    }
  }

  /* Matrix Rain Effect */
  .matrix-rain {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .rain-column {
    position: absolute;
    top: -100%;
    font-family: "Courier New", monospace;
    font-size: 12px;
    color: rgba(0, 255, 0, 0.3);
    animation: matrixRain 4s linear infinite;
    white-space: nowrap;
  }

  .rain-char {
    display: block;
    line-height: 1.2;
    animation: charFlicker 0.5s ease-in-out infinite;
  }

  @keyframes matrixRain {
    0% {
      transform: translateY(-100%);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateY(calc(100vh + 100%));
      opacity: 0;
    }
  }

  @keyframes charFlicker {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.8;
    }
  }

  /* Position rain columns */
  .rain-column-1 {
    left: 5%;
  }
  .rain-column-2 {
    left: 12%;
  }
  .rain-column-3 {
    left: 19%;
  }
  .rain-column-4 {
    left: 26%;
  }
  .rain-column-5 {
    left: 33%;
  }
  .rain-column-6 {
    left: 40%;
  }
  .rain-column-7 {
    left: 47%;
  }
  .rain-column-8 {
    left: 54%;
  }
  .rain-column-9 {
    left: 61%;
  }
  .rain-column-10 {
    left: 68%;
  }
  .rain-column-11 {
    left: 75%;
  }
  .rain-column-12 {
    left: 82%;
  }

  .steps-status {
    font-family: "Courier New", monospace;
  }

  .status-block {
    padding: 8px 12px;
    background: rgba(0, 255, 0, 0.05);
    border: 1px solid rgba(0, 255, 0, 0.1);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .steps-count-container {
      padding: 16px;
    }

    .count-value span {
      font-size: 2.5rem;
    }

    .steps-status .grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
