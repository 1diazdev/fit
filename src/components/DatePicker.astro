---
/**
 * Matrix-themed Date Picker using Flatpickr
 * Mobile-friendly date selection component
 */

interface Props {
  selectedDate: string; // YYYY-MM-DD format
  minDate?: string; // Minimum selectable date (YYYY-MM-DD format)
  baseUrl?: string; // Base URL for navigation (default: current page)
  label?: string; // Label for the picker
}

const { selectedDate, minDate, baseUrl = "", label = "[SELECT_DATE]" } = Astro.props;

// Generate unique ID for this instance
const pickerId = `datepicker-${Math.random().toString(36).substr(2, 9)}`;

// Calculate max date (today)
const today = new Date();
const maxDate = today.toISOString().split("T")[0];
---

<div class="matrix-datepicker-wrapper">
  <label for={pickerId} class="datepicker-label">{label}</label>
  <div class="datepicker-input-wrapper">
    <input
      type="text"
      id={pickerId}
      class="datepicker-input"
      value={selectedDate}
      placeholder="Select date..."
      data-base-url={baseUrl}
      data-min-date={minDate}
      data-max-date={maxDate}
      readonly
    />
    <svg
      class="calendar-icon"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
      ></path>
    </svg>
  </div>
</div>

<style is:global>
  /* Flatpickr Matrix Theme */
  .flatpickr-calendar {
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.95) 0%,
      rgba(0, 20, 0, 0.9) 100%
    ) !important;
    border: 2px solid rgba(0, 255, 0, 0.4) !important;
    border-radius: 8px !important;
    box-shadow:
      0 10px 40px rgba(0, 255, 0, 0.3),
      inset 0 0 20px rgba(0, 255, 0, 0.05) !important;
    font-family: "Courier New", monospace !important;
  }

  .flatpickr-months {
    background: rgba(0, 0, 0, 0.5) !important;
    border-bottom: 1px solid rgba(0, 255, 0, 0.3) !important;
  }

  .flatpickr-month {
    color: #00ff00 !important;
  }

  .flatpickr-current-month {
    color: #00ff00 !important;
    font-weight: bold !important;
  }

  .flatpickr-current-month .flatpickr-monthDropdown-months {
    background: rgba(0, 0, 0, 0.8) !important;
    border: 1px solid rgba(0, 255, 0, 0.3) !important;
    color: #00ff00 !important;
  }

  .flatpickr-current-month .flatpickr-monthDropdown-months:hover {
    background: rgba(0, 255, 0, 0.1) !important;
  }

  .flatpickr-current-month input.cur-year {
    color: #00ff00 !important;
    background: rgba(0, 0, 0, 0.5) !important;
    border: 1px solid rgba(0, 255, 0, 0.3) !important;
    font-weight: bold !important;
  }

  .flatpickr-prev-month,
  .flatpickr-next-month {
    color: #00ff00 !important;
    fill: #00ff00 !important;
  }

  .flatpickr-prev-month:hover,
  .flatpickr-next-month:hover {
    background: rgba(0, 255, 0, 0.2) !important;
  }

  .flatpickr-weekdays {
    background: rgba(0, 0, 0, 0.3) !important;
  }

  .flatpickr-weekday {
    color: rgba(0, 255, 0, 0.7) !important;
    font-weight: bold !important;
  }

  .flatpickr-days {
    background: rgba(0, 0, 0, 0.2) !important;
  }

  .flatpickr-day {
    color: rgba(0, 255, 0, 0.8) !important;
    border: 1px solid transparent !important;
  }

  .flatpickr-day:hover:not(.flatpickr-disabled) {
    background: rgba(0, 255, 0, 0.2) !important;
    border-color: rgba(0, 255, 0, 0.5) !important;
    color: #00ff00 !important;
  }

  .flatpickr-day.today {
    border-color: rgba(0, 255, 0, 0.6) !important;
    background: rgba(0, 255, 0, 0.1) !important;
    color: #00ff00 !important;
  }

  .flatpickr-day.selected {
    background: rgba(0, 255, 0, 0.3) !important;
    border-color: #00ff00 !important;
    color: #00ff00 !important;
    font-weight: bold !important;
    box-shadow:
      0 0 15px rgba(0, 255, 0, 0.5),
      inset 0 0 10px rgba(0, 255, 0, 0.2) !important;
  }

  .flatpickr-day.flatpickr-disabled {
    color: rgba(0, 255, 0, 0.2) !important;
    cursor: not-allowed !important;
  }

  .flatpickr-day.prevMonthDay,
  .flatpickr-day.nextMonthDay {
    color: rgba(0, 255, 0, 0.3) !important;
  }

  .flatpickr-time {
    border-top: 1px solid rgba(0, 255, 0, 0.3) !important;
    background: rgba(0, 0, 0, 0.5) !important;
  }

  /* Mobile optimizations */
  @media (max-width: 768px) {
    .flatpickr-calendar {
      width: min(350px, calc(100vw - 2rem)) !important;
    }

    .flatpickr-day {
      height: 42px !important;
      line-height: 42px !important;
      max-width: 42px !important;
    }
  }
</style>

<style>
  .matrix-datepicker-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    max-width: 320px;
  }

  .datepicker-label {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    color: rgba(0, 255, 0, 0.8);
    letter-spacing: 0.05em;
    font-weight: bold;
  }

  .datepicker-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .datepicker-input {
    width: 100%;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 6px;
    color: #00ff00;
    font-family: "Courier New", monospace;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .datepicker-input:hover {
    background: rgba(0, 255, 0, 0.1);
    border-color: rgba(0, 255, 0, 0.5);
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
  }

  .datepicker-input:focus {
    outline: none;
    border-color: rgba(0, 255, 0, 0.6);
    box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
  }

  .calendar-icon {
    position: absolute;
    right: 0.75rem;
    width: 20px;
    height: 20px;
    color: rgba(0, 255, 0, 0.7);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .matrix-datepicker-wrapper {
      max-width: 100%;
    }

    .datepicker-input {
      font-size: 16px; /* Prevents zoom on iOS */
    }
  }
</style>

<script>
  import flatpickr from "flatpickr";
  import "flatpickr/dist/flatpickr.min.css";

  document.addEventListener("DOMContentLoaded", () => {
    const inputs = document.querySelectorAll(
      ".datepicker-input",
    ) as NodeListOf<HTMLInputElement>;

    inputs.forEach(input => {
      const baseUrl = input.dataset.baseUrl || "";
      const minDate = input.dataset.minDate;
      const maxDate = input.dataset.maxDate || new Date();

      flatpickr(input, {
        dateFormat: "Y-m-d",
        minDate: minDate,
        maxDate: maxDate,
        defaultDate: input.value,
        allowInput: false,
        disableMobile: false, // Use flatpickr on mobile too
        monthSelectorType: "static",
        onChange: (selectedDates, dateStr) => {
          if (dateStr) {
            // Navigate to the selected date
            // If baseUrl is provided, use query parameter format
            // Otherwise use /day/YYYY-MM-DD format
            if (baseUrl) {
              window.location.href = `${baseUrl}?date=${dateStr}`;
            } else {
              window.location.href = `/day/${dateStr}`;
            }
          }
        },
        onReady: (selectedDates, dateStr, instance) => {
          // Add custom class to calendar
          if (instance.calendarContainer) {
            instance.calendarContainer.classList.add("matrix-calendar");
          }
        },
      });
    });
  });
</script>
