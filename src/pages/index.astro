---
import Base from "@layouts/Base.astro";
import { PAGE_METADATA } from "@src/consts";
import SectionLayout from "@components/SectionLayout.astro";
import DayMetricsGrid from "@components/DayMetricsGrid.astro";
import DaysSinceLast from "@components/DaysSinceLast.astro";
import MinimalDaysSince from "@components/MinimalDaysSince.astro";
import InsightsPanel from "@components/InsightsPanel.astro";
import { Flame, Zap, Dumbbell } from "lucide-astro";
import MoveMinutesChart from "@components/MoveMinutesChart.astro";
import HeartRateZones from "@components/HeartRateZones.astro";
import HeatmapGrid from "@components/HeatmapGrid.astro";
import ActivityDashboard from "@components/ActivityDashboard.astro";
import HevyWorkoutCount from "@components/HevyWorkoutCount.astro";
import DayComparison from "@components/DayComparison.astro";

import {
  getDataForDate,
  getComparisons,
  calculateStreaks,
  isTestDataMode,
  getTestModeSnapshot,
} from "@services/dataAggregationService";
import {
  fetchDistanceData,
  processDistanceData,
  fetchActivities,
} from "@services/stravaService";
import {
  fetchStepsData,
  fetchHeartRateData,
  fetchMoveMinutesData,
} from "@services/googleFitService";
import { generateInsights, getPersonalRecords } from "@utils/statsUtils";
import { fetchHevyData, fetchWorkoutCount } from "@services/hevyService";

// WORKAROUND: Query parameters don't work in Astro dev server
// Load today's data by default, client-side will handle date navigation
const today = new Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, "0")}-${String(today.getDate()).padStart(2, "0")}`;
const selectedDate = todayStr; // Always use today for SSR

// Parse date string properly to avoid timezone issues
// YYYY-MM-DD format should be interpreted as local date, not UTC
const [year, month, day] = selectedDate.split("-").map(Number);
const selectedDateObj = new Date(year, month - 1, day); // month is 0-indexed

// Calculate previous and next day dates
const prevDay = new Date(selectedDateObj);
prevDay.setDate(prevDay.getDate() - 1);
const prevDayStr = `${prevDay.getFullYear()}-${String(prevDay.getMonth() + 1).padStart(2, "0")}-${String(prevDay.getDate()).padStart(2, "0")}`;

const nextDay = new Date(selectedDateObj);
nextDay.setDate(nextDay.getDate() + 1);
const nextDayStr = `${nextDay.getFullYear()}-${String(nextDay.getMonth() + 1).padStart(2, "0")}-${String(nextDay.getDate()).padStart(2, "0")}`;

// Format date for display
const displayDate = new Intl.DateTimeFormat("en-US", {
  weekday: "short",
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: "UTC",
}).format(new Date(Date.UTC(year, month - 1, day, 12)));

// Check if selected date is today
const isToday = selectedDate === todayStr;
const isNextDayFuture = nextDayStr > todayStr;

console.log(
  `[index.astro] ====== Loading dashboard for date: ${selectedDate} ======`,
);
console.log(
  `[index.astro] Today: ${todayStr}, Selected: ${selectedDate}, Is Today: ${selectedDate === todayStr}`,
);

// Fetch all data for selected date
const dayData = await getDataForDate(selectedDate);
console.log(`[index.astro] DayData fetched:`, {
  steps: dayData.steps.count,
  activities: dayData.activities.length,
  workouts: dayData.workouts.length,
});

const comparisons = await getComparisons(selectedDate);
const streaks = await calculateStreaks(selectedDate);
const testMode = isTestDataMode();
const testSnapshot = testMode ? await getTestModeSnapshot() : null;

// Fetch data for insights generation
const [stepsData, allActivities, allWorkouts] =
  testMode && testSnapshot
    ? [testSnapshot.stepsData, testSnapshot.activities, testSnapshot.workouts]
    : await Promise.all([
        fetchStepsData(365).catch(() => ({})),
        fetchActivities(1, 200).catch(() => []),
        fetchHevyData().catch(() => []),
      ]);

const personalRecords = getPersonalRecords(
  stepsData,
  allActivities,
  allWorkouts,
);
const insights = generateInsights(
  dayData,
  comparisons,
  streaks,
  personalRecords,
);

// Pre-calculate activity data for the dashboard (using selected date data)
// Note: ActivityDashboard shows "days since last" globally, not for specific date
// We'll use the dayData.activities for the selected date instead
const findLastActivityByType = (type: string) => {
  const activity = allActivities.find(a => {
    const activityType = a.type || a.sport_type || "";
    return (
      activityType.toLowerCase() === type.toLowerCase() ||
      a.name.toLowerCase().includes(type.toLowerCase())
    );
  });

  if (!activity) return null;

  const activityDate = new Date(activity.start_date);
  const newYorkDate = new Date(
    activityDate.toLocaleString("en-US", { timeZone: "America/New_York" }),
  );

  return { date: newYorkDate, activity };
};

const activityData = {
  run: findLastActivityByType("run"),
  ride: findLastActivityByType("ride"),
  swim: findLastActivityByType("swim"),
  walk: findLastActivityByType("walk"),
};

// For the selected date, show if there were activities
// This will make the activity cards update based on selected date
const selectedDateActivitiesByType = {
  run: dayData.activities.find(
    a => (a.type || a.sport_type || "").toLowerCase() === "run",
  ),
  ride: dayData.activities.find(
    a => (a.type || a.sport_type || "").toLowerCase() === "ride",
  ),
  swim: dayData.activities.find(
    a => (a.type || a.sport_type || "").toLowerCase() === "swim",
  ),
  walk: dayData.activities.find(a =>
    (a.type || a.sport_type || "").toLowerCase().includes("walk"),
  ),
};

// Fetch 365-day heatmap data
const distanceMap =
  testMode && testSnapshot
    ? testSnapshot.distanceMap
    : await fetchDistanceData();
const distanceData = processDistanceData(distanceMap);
const positiveDistances = distanceData
  .map(data => data[1])
  .filter(value => value > 0);
const minDistance =
  positiveDistances.length > 0 ? Math.min(...positiveDistances) : 0;
const maxDistance =
  positiveDistances.length > 0 ? Math.max(...positiveDistances) : 1;

// Fetch move minutes for chart (last 7 days)
const moveMinutesData =
  testMode && testSnapshot
    ? testSnapshot.moveMinutesData
    : await fetchMoveMinutesData(30).catch(() => ({}));

// Fetch heart rate data for zones component
const heartRateData =
  testMode && testSnapshot
    ? testSnapshot.heartRateData
    : await fetchHeartRateData(7).catch(() => ({}));

// Fetch Hevy workout count
let workoutCount = 0;
if (testMode && testSnapshot) {
  workoutCount = testSnapshot.workoutCount;
} else {
  try {
    workoutCount = await fetchWorkoutCount();
  } catch (error) {
    console.error("Error fetching workout count:", error);
    workoutCount = 0;
  }
}

// Generate terminal command with date
const terminalCommand = `./view_metrics.sh ${selectedDate}`;

// Generate system message with API status
const hasSteps = dayData.steps.count > 0;
const hasActivities = dayData.activities.length > 0;
const hasWorkouts = dayData.workouts.length > 0;
const modeLabel = testMode ? "TEST" : "LIVE";
const systemMessage = `${selectedDate} | Fit: ${hasSteps ? "✓" : "○"} | Strava: ${hasActivities ? "✓" : "○"} | Hevy: ${hasWorkouts ? "✓" : "○"}`;
---

<Base
  title={PAGE_METADATA.index.title}
  description={PAGE_METADATA.index.description}
  keywords={PAGE_METADATA.index.keywords}
  windowTitle="FITNESS_DASHBOARD"
  terminalCommand={terminalCommand}
  systemMessage={systemMessage}
>
  <!-- Date Navigator - Uses /day/YYYY-MM-DD routes -->
  <div class="date-navigator">
    <a href={`/day/${prevDayStr}`} class="nav-arrow" title="Previous day">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
    </a>

    <div class="date-display">
      <div class="date-text">{displayDate}</div>
    </div>

    <a
      href={isNextDayFuture ? "#" : `/day/${nextDayStr}`}
      class={`nav-arrow ${isNextDayFuture ? "disabled" : ""}`}
      title="Next day"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <!-- Daily Metrics Grid -->
  <SectionLayout title="[DAILY_METRICS]">
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
    >
    </div>
    <DayMetricsGrid dayData={dayData} />
  </SectionLayout>

  <!-- Insights & Comparisons -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <SectionLayout title="[INSIGHTS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse"
      >
      </div>
      <InsightsPanel insights={insights} />
    </SectionLayout>

    <SectionLayout title="[COMPARISONS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"
      >
      </div>
      <DayComparison comparisons={comparisons} />
    </SectionLayout>
  </div>

  <!-- Charts Section -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <SectionLayout title="[MOVE_MINUTES]" rightHeaderText="[LAST_7_DAYS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-purple-400 rounded-full animate-pulse"
      >
      </div>
      <MoveMinutesChart moveMinutesData={moveMinutesData} days={7} />
    </SectionLayout>

    <SectionLayout title="[HEART_RATE_ZONES]" rightHeaderText="[LAST_7_DAYS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-red-400 rounded-full animate-pulse"
      >
      </div>
      <HeartRateZones heartRateData={heartRateData} daysToShow={7} />
    </SectionLayout>
  </div>

  <!-- Activity Status Section -->
  <SectionLayout title="[ACTIVITY_STATUS]" rightHeaderText="[DAYS_SINCE_LAST]">
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
    >
    </div>
    <ActivityDashboard activityData={activityData} />
  </SectionLayout>

  <!-- Hevy Workout Count Section -->
  <SectionLayout title="[HEVY_WORKOUT]" rightHeaderText="[TOTAL_WORKOUT_COUNT]">
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
    >
    </div>
    <HevyWorkoutCount workoutCount={workoutCount} />
  </SectionLayout>

  <!-- 365-Day Heatmap (Annual Overview) -->
  <SectionLayout
    title="[ANNUAL_OVERVIEW]"
    rightHeaderText="[365_DAY_ACTIVITY_MAP]"
  >
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
    >
    </div>
    <div class="heatmap-container">
      <div class="heatmap-wrapper">
        <!-- Heatmap Header Info -->
        <div class="heatmap-info mb-4">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs">
            <div class="info-block">
              <span class="text-green-400/60">DATA_RANGE:</span>
              <span class="text-green-300 ml-2">365 DAYS</span>
            </div>
            <div class="info-block">
              <span class="text-green-400/60">MIN_ACTIVITY:</span>
              <span class="text-green-300 ml-2"
                >{minDistance.toFixed(1)} KM</span
              >
            </div>
            <div class="info-block">
              <span class="text-green-400/60">MAX_ACTIVITY:</span>
              <span class="text-green-300 ml-2"
                >{maxDistance.toFixed(1)} KM</span
              >
            </div>
          </div>
        </div>

        <!-- Main Heatmap Grid -->
        <div class="heatmap-display">
          <HeatmapGrid
            distanceData={distanceData}
            minDistance={minDistance}
            maxDistance={maxDistance}
          />
        </div>

        <!-- Heatmap Footer Info with Strava Button -->
        <div class="heatmap-footer mt-4">
          <div class="flex justify-between items-center text-xs">
            <div class="flex items-center space-x-4">
              <span class="text-green-400/60">NEURAL_ACTIVITY_TRACKING</span>
              <div class="flex items-center space-x-1">
                <div class="w-1 h-1 bg-green-500 rounded-full animate-pulse">
                </div>
                <span class="text-green-500">ONLINE</span>
              </div>
            </div>

            <!-- Strava Activities Button -->
            <a
              href="https://www.strava.com/athletes/47698767"
              target="_blank"
              rel="noopener noreferrer"
              class="strava-link-button group"
            >
              <span
                class="text-green-300 hover:text-green-100 transition-colors duration-300 font-mono text-xs flex items-center space-x-2"
              >
                <span>[VERIFY_ON_STRAVA]</span>
                <svg
                  class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </SectionLayout>

  <!-- Streaks Info (small footer section) -->
  <SectionLayout title="[ACTIVE_STREAKS]">
    <div class="streaks-grid">
      {
        streaks.steps.current > 0 && (
          <div class="streak-card">
            <span class="streak-icon">
              <Flame size={16} />
            </span>
            <div class="streak-info">
              <div class="streak-value">{streaks.steps.current} days</div>
              <div class="streak-label">Step Goal Streak</div>
              <div class="streak-record">
                Best: {streaks.steps.longest} days
              </div>
            </div>
          </div>
        )
      }
      {
        streaks.activities.current > 0 && (
          <div class="streak-card">
            <span class="streak-icon">
              <Zap size={16} />
            </span>
            <div class="streak-info">
              <div class="streak-value">{streaks.activities.current} days</div>
              <div class="streak-label">Activity Streak</div>
              <div class="streak-record">
                Best: {streaks.activities.longest} days
              </div>
            </div>
          </div>
        )
      }
      {
        streaks.workouts.current > 0 && (
          <div class="streak-card">
            <span class="streak-icon">
              <Dumbbell size={16} />
            </span>
            <div class="streak-info">
              <div class="streak-value">{streaks.workouts.current} days</div>
              <div class="streak-label">Workout Streak</div>
              <div class="streak-record">
                Best: {streaks.workouts.longest} days
              </div>
            </div>
          </div>
        )
      }
    </div>
  </SectionLayout>
</Base>

<style>
  /* Heatmap styles */
  .heatmap-container {
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 20, 0, 0.6) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 8px;
    padding: 20px;
    box-shadow:
      0 0 20px rgba(0, 255, 0, 0.2),
      inset 0 0 20px rgba(0, 255, 0, 0.05);
    position: relative;
    overflow: hidden;
  }

  .heatmap-wrapper {
    position: relative;
    z-index: 2;
  }

  .heatmap-display {
    max-width: 1200px;
    margin: 0 auto;
    aspect-ratio: 53/7;
  }

  .heatmap-info,
  .heatmap-footer {
    font-family: "Courier New", monospace;
  }

  .info-block {
    padding: 4px 0;
  }

  .strava-link-button {
    position: relative;
    padding: 6px 12px;
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 4px;
    background: rgba(0, 255, 0, 0.05);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .strava-link-button:hover {
    background: rgba(0, 255, 0, 0.1);
    border-color: rgba(0, 255, 0, 0.6);
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
    transform: translateY(-1px);
  }

  /* Streaks Grid */
  .streaks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  .streak-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 20, 0, 0.5) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 6px;
    transition: all 0.3s ease;
  }

  .streak-card:hover {
    border-color: rgba(0, 255, 0, 0.5);
    box-shadow: 0 0 15px rgba(0, 255, 0, 0.2);
    transform: translateY(-2px);
  }

  .streak-icon {
    font-size: 2rem;
    animation: pulse 2s ease-in-out infinite;
  }

  .streak-info {
    flex: 1;
    font-family: "Courier New", monospace;
  }

  .streak-value {
    font-size: 1.5rem;
    font-weight: bold;
    color: #00ff00;
    margin-bottom: 0.25rem;
  }

  .streak-label {
    font-size: 0.75rem;
    color: rgba(0, 255, 0, 0.7);
    margin-bottom: 0.25rem;
  }

  .streak-record {
    font-size: 0.65rem;
    color: rgba(0, 255, 0, 0.5);
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
    }
  }

  /* Date Navigator */
  .date-navigator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 1.5rem 1rem;
    margin-bottom: 2rem;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 20, 0, 0.6) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 8px;
    font-family: "Courier New", monospace;
  }

  .nav-arrow {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 6px;
    color: #00ff00;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .nav-arrow:hover {
    background: rgba(0, 255, 0, 0.15);
    border-color: rgba(0, 255, 0, 0.6);
    box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
    transform: scale(1.1);
  }

  .nav-arrow.disabled,
  .nav-arrow.disabled:hover {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
    transform: none;
    box-shadow: none;
  }

  .nav-arrow svg {
    width: 20px;
    height: 20px;
  }

  .date-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 280px;
  }

  .date-text {
    font-size: 1.25rem;
    font-weight: bold;
    color: #00ff00;
    text-align: center;
    letter-spacing: 0.05em;
    text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
  }

  .today-btn {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 255, 0, 0.1);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 4px;
    color: rgba(0, 255, 0, 0.8);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .today-btn:hover {
    background: rgba(0, 255, 0, 0.2);
    border-color: rgba(0, 255, 0, 0.5);
    color: #00ff00;
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .heatmap-container {
      padding: 12px;
    }

    .streaks-grid {
      grid-template-columns: 1fr;
    }

    .streak-icon {
      font-size: 1.5rem;
    }

    .streak-value {
      font-size: 1.25rem;
    }

    .date-navigator {
      gap: 1rem;
      padding: 1rem;
    }

    .nav-arrow {
      width: 36px;
      height: 36px;
    }

    .date-display {
      min-width: 200px;
    }

    .date-text {
      font-size: 1rem;
    }
  }
</style>
