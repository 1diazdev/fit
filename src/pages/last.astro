---
import SectionLayout from "@components/SectionLayout.astro";
import DaysSinceLast from "@components/DaysSinceLast.astro";
import Base from "@layouts/Base.astro";
import { PAGE_METADATA } from "@src/consts";
import { loadAllDataFromJSON } from "@lib/jsonLoader";
import { BarChart3, ClipboardList, TrendingUp } from "lucide-astro";

// Load activities from JSON to avoid API calls
const jsonData = await loadAllDataFromJSON();
const allActivities = jsonData?.strava.activities || [];

// Helper function to find last activity by type
const findLastActivityByType = (type: string) => {
  const activity = allActivities.find(a => {
    const activityType = a.type || a.sport_type || "";
    return (
      activityType.toLowerCase() === type.toLowerCase() ||
      a.name.toLowerCase().includes(type.toLowerCase())
    );
  });

  if (!activity) return null;

  const activityDate = new Date(activity.start_date);
  const newYorkDate = new Date(
    activityDate.toLocaleString("en-US", { timeZone: "America/New_York" }),
  );

  return newYorkDate;
};

// Get last activity dates using the optimized single fetch
const lastRunDate = findLastActivityByType("Run");
const lastRideDate = findLastActivityByType("Ride");
const lastSwimDate = findLastActivityByType("Swim");

// Calculate REAL weekly averages from Strava API
const calculateWeeklyStats = (activityType: string) => {
  const weekAgo = new Date();
  weekAgo.setDate(weekAgo.getDate() - 7);

  const weekActivities = allActivities.filter(activity => {
    const activityDate = new Date(activity.start_date);
    const type = activity.type || activity.sport_type || "";
    const matchesType =
      type.toLowerCase() === activityType.toLowerCase() ||
      activity.name.toLowerCase().includes(activityType.toLowerCase());
    return matchesType && activityDate >= weekAgo;
  });

  const totalDistance =
    weekActivities.reduce((sum, a) => sum + (a.distance || 0), 0) / 1000; // km
  return totalDistance;
};

// Get REAL last activity details from Strava
const getLastActivityDetails = (activityType: string) => {
  const activity = allActivities.find(a => {
    const type = a.type || a.sport_type || "";
    return (
      type.toLowerCase() === activityType.toLowerCase() ||
      a.name.toLowerCase().includes(activityType.toLowerCase())
    );
  });

  if (!activity) {
    return { distance: 0, duration: 0, stravaUrl: "", name: "" };
  }

  return {
    distance: (activity.distance || 0) / 1000, // Convert to km
    duration: activity.moving_time || 0, // seconds
    stravaUrl: `https://www.strava.com/activities/${activity.id}`,
    name: activity.name || "",
  };
};

// Get activity details
const runDetails = getLastActivityDetails("Run");
const rideDetails = getLastActivityDetails("Ride");
const swimDetails = getLastActivityDetails("Swim");

// Calculate REAL weekly stats
const weeklyRunDistance = calculateWeeklyStats("Run");
const weeklyRideDistance = calculateWeeklyStats("Ride");
const weeklySwimDistance = calculateWeeklyStats("Swim");

// Calculate total weekly activities (last 7 days)
const weekAgo = new Date();
weekAgo.setDate(weekAgo.getDate() - 7);
const weekActivities = allActivities.filter(activity => {
  const activityDate = new Date(activity.start_date);
  return activityDate >= weekAgo;
});
const totalWeeklyActivities = weekActivities.length;
const totalWeeklyDistance =
  weekActivities.reduce((sum, a) => sum + (a.distance || 0), 0) / 1000; // km
const totalWeeklyTime = weekActivities.reduce(
  (sum, a) => sum + (a.moving_time || 0),
  0,
); // seconds

// Calculate discipline count (how many types of activities)
const disciplineTypes = new Set(
  allActivities
    .slice(0, 50)
    .map(a => a.type || a.sport_type)
    .filter(Boolean),
);
const totalDisciplines = disciplineTypes.size;
const pageParam = Astro.url.searchParams.get("page");
let currentPage = 1;
if (pageParam) {
  const parsedPage = parseInt(pageParam, 10);
  if (!isNaN(parsedPage) && parsedPage > 0) {
    currentPage = parsedPage;
  }
}
---

<Base
  title={PAGE_METADATA.last.title}
  description={PAGE_METADATA.last.description}
  keywords={PAGE_METADATA.last.keywords}
  title="Activity Status Monitor"
  windowTitle="ACTIVITY_TRACKER"
  terminalCommand="./view_activities.sh --last-7-days"
  systemMessage={`[SYSTEM] Last ${totalWeeklyActivities} activities | Total: ${totalWeeklyDistance.toFixed(1)} km | Disciplines: ${totalDisciplines}`}
>
  <!-- Activity Cards Grid - Desktop: 3 columns, Mobile: stack -->
  <section class="mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Running Activity Section -->
      <SectionLayout
        title="[RUNNING_MODULE]"
        titleClass="text-sm font-mono"
        rightHeaderText="CARDIOVASCULAR"
        sectionClass="activity-section"
        headerClass="mb-3 text-green-400 text-xs"
      >
        <div
          slot="headerElements"
          class="flex-1 h-px bg-gradient-to-r from-green-500/50 via-green-500/20 to-transparent"
        >
        </div>
        <DaysSinceLast
          lastRunDate={lastRunDate || new Date()}
          activityType="RUN"
          stravaUrl={runDetails.stravaUrl}
          lastDistance={runDetails.distance || 0}
          lastDuration={runDetails.duration || 0}
          averageWeekly={weeklyRunDistance}
          lastActivityName={runDetails.name}
        />
      </SectionLayout>

      <!-- Cycling Activity Section -->
      <SectionLayout
        title="[CYCLING_MODULE]"
        titleClass="text-sm font-mono"
        rightHeaderText="ENDURANCE"
        sectionClass="activity-section"
        headerClass="mb-3 text-green-400 text-xs"
      >
        <div
          slot="headerElements"
          class="flex-1 h-px bg-gradient-to-r from-green-500/50 via-green-500/20 to-transparent"
        >
        </div>
        <DaysSinceLast
          lastRunDate={lastRideDate || new Date()}
          activityType="RIDE"
          stravaUrl={rideDetails.stravaUrl}
          lastDistance={rideDetails.distance || 0}
          lastDuration={rideDetails.duration || 0}
          averageWeekly={weeklyRideDistance}
          lastActivityName={rideDetails.name}
        />
      </SectionLayout>

      <!-- Swimming Activity Section -->
      <SectionLayout
        title="[SWIMMING_MODULE]"
        titleClass="text-sm font-mono"
        rightHeaderText="AQUATIC"
        sectionClass="activity-section"
        headerClass="mb-3 text-green-400 text-xs"
      >
        <div
          slot="headerElements"
          class="flex-1 h-px bg-gradient-to-r from-green-500/50 via-green-500/20 to-transparent"
        >
        </div>
        <DaysSinceLast
          lastRunDate={lastSwimDate || new Date()}
          activityType="Swim"
          stravaUrl={swimDetails.stravaUrl}
          lastDistance={swimDetails.distance || 0}
          lastDuration={swimDetails.duration || 0}
          averageWeekly={weeklySwimDistance}
          lastActivityName={swimDetails.name}
        />
      </SectionLayout>
    </div>
  </section>

  <!-- Training Summary Section - REAL DATA -->
  <section class="mb-6">
    <div
      class="bg-black/60 border border-green-500/30 rounded-lg p-4 backdrop-blur-sm"
    >
      <div class="text-center space-y-3">
        <div class="text-green-400 font-mono text-sm mb-2">
          [WEEKLY_TRAINING_SUMMARY]
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
          <div class="space-y-1">
            <div class="text-green-400/60 text-xs">TOTAL_ACTIVITIES:</div>
            <div class="text-green-300 font-mono text-lg">
              {totalWeeklyActivities}
            </div>
            <div class="text-green-400/80 text-xs">LAST_7_DAYS</div>
          </div>

          <div class="space-y-1">
            <div class="text-green-400/60 text-xs">TOTAL_DISTANCE:</div>
            <div class="text-green-300 font-mono text-lg">
              {totalWeeklyDistance.toFixed(1)} km
            </div>
            <div class="text-green-400/80 text-xs">LAST_7_DAYS</div>
          </div>

          <div class="space-y-1">
            <div class="text-green-400/60 text-xs">TOTAL_TIME:</div>
            <div class="text-green-300 font-mono text-lg">
              {Math.floor(totalWeeklyTime / 3600)}h {
                Math.floor((totalWeeklyTime % 3600) / 60)
              }m
            </div>
            <div class="text-green-400/80 text-xs">MOVING_TIME</div>
          </div>

          <div class="space-y-1">
            <div class="text-green-400/60 text-xs">DISCIPLINES:</div>
            <div class="text-green-300 font-mono text-lg">
              {totalDisciplines}
            </div>
            <div class="text-green-400/80 text-xs">TYPES_TRACKED</div>
          </div>
        </div>

        <div class="mt-3 pt-3 border-t border-green-500/20">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-xs">
            <div class="space-y-1">
              <div class="text-green-400/60">RUNNING:</div>
              <div class="text-green-300 font-mono">
                {weeklyRunDistance.toFixed(1)} km/week
              </div>
            </div>
            <div class="space-y-1">
              <div class="text-green-400/60">CYCLING:</div>
              <div class="text-green-300 font-mono">
                {weeklyRideDistance.toFixed(1)} km/week
              </div>
            </div>
            <div class="space-y-1">
              <div class="text-green-400/60">SWIMMING:</div>
              <div class="text-green-300 font-mono">
                {weeklySwimDistance.toFixed(1)} km/week
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Actions Section -->
  <section>
    <div class="text-center space-y-3">
      <div class="text-green-400 font-mono text-sm mb-2">[QUICK_ACTIONS]</div>

      <div
        class="flex flex-col sm:flex-row gap-3 justify-center max-w-2xl mx-auto"
      >
        <a
          href="https://www.strava.com/dashboard"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 px-4 py-2 bg-orange-500/20 border border-orange-500/40 text-orange-400 rounded-lg font-mono text-sm hover:bg-orange-500/30 hover:border-orange-500/60 transition-all duration-300 transform hover:scale-105 no-underline hover:no-underline"
        >
          <span class="flex items-center justify-center space-x-2">
            <BarChart3 size={16} />
            <span>STRAVA_DASHBOARD</span>
          </span>
        </a>

        <button
          class="flex-1 px-4 py-2 bg-blue-500/20 border border-blue-500/40 text-blue-400 rounded-lg font-mono text-sm hover:bg-blue-500/30 hover:border-blue-500/60 transition-all duration-300 transform hover:scale-105 training-plan-btn"
        >
          <span class="flex items-center justify-center space-x-2">
            <ClipboardList size={16} />
            <span>TRAINING_PLAN</span>
          </span>
        </button>

        <button
          class="flex-1 px-4 py-2 bg-purple-500/20 border border-purple-500/40 text-purple-400 rounded-lg font-mono text-sm hover:bg-purple-500/30 hover:border-purple-500/60 transition-all duration-300 transform hover:scale-105 analytics-btn"
        >
          <span class="flex items-center justify-center space-x-2">
            <TrendingUp size={16} />
            <span>ANALYTICS</span>
          </span>
        </button>
      </div>
    </div>
  </section>
</Base>

<style>
  .activity-section {
    transition: all 0.3s ease;
  }

  .activity-section:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .activity-section {
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const trainingPlanBtn = document.querySelector(".training-plan-btn");
    trainingPlanBtn?.addEventListener("click", () => {
      showModal(
        "Training Plan",
        `
        <div class="space-y-4 text-left">
          <div class="text-green-400 text-sm">WEEKLY_SCHEDULE:</div>
          <div class="space-y-2 text-sm text-green-300">
            <div>• MONDAY: Rest or light swim (30-45min)</div>
            <div>• TUESDAY: Run - Tempo/Intervals (45-60min)</div>
            <div>• WEDNESDAY: Bike - Endurance ride (60-90min)</div>
            <div>• THURSDAY: Run - Easy pace (30-45min)</div>
            <div>• FRIDAY: Swim - Technique focus (45min)</div>
            <div>• SATURDAY: Bike - Long ride (90-120min)</div>
            <div>• SUNDAY: Run - Long run (60-90min)</div>
          </div>
          <div class="mt-4 pt-4 border-t border-green-500/20 text-xs text-green-400/80">
            Adjust intensity based on current fitness level and recovery status.
          </div>
        </div>
      `,
      );
    });

    const analyticsBtn = document.querySelector(".analytics-btn");
    analyticsBtn?.addEventListener("click", () => {
      showModal(
        "Performance Analytics",
        `
        <div class="space-y-4 text-left">
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div class="space-y-2">
              <div class="text-green-400 text-xs">RUNNING_METRICS:</div>
              <div class="text-green-300 font-mono text-xs">
                Avg Pace: 5:12/km<br>
                Weekly: 25.5km<br>
                Trend: ↗ +8%
              </div>
            </div>
            <div class="space-y-2">
              <div class="text-green-400 text-xs">CYCLING_METRICS:</div>
              <div class="text-green-300 font-mono text-xs">
                Avg Speed: 28.3km/h<br>
                Weekly: 45.2km<br>
                Trend: ↗ +12%
              </div>
            </div>
          </div>
          <div class="space-y-2">
            <div class="text-green-400 text-xs">SWIMMING_METRICS:</div>
            <div class="text-green-300 font-mono text-xs">
              Avg Pace: 2:15/100m | Weekly: 2.8km | Trend: → Stable
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-green-500/20">
            <div class="text-green-400 text-xs mb-2">RECOMMENDATIONS:</div>
            <div class="text-green-300 text-xs">
              • Increase swimming volume by 10-15%<br>
              • Maintain current running consistency<br>
              • Consider adding bike hill training
            </div>
          </div>
        </div>
      `,
      );
    });

    function showModal(title: string, content: string) {
      const modal = document.createElement("div");
      modal.className =
        "fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4";
      modal.innerHTML = `
        <div class="bg-black/90 border border-green-500/40 rounded-lg p-6 max-w-lg w-full max-h-[80vh] overflow-y-auto">
          <div class="space-y-4">
            <div class="text-green-400 text-lg font-mono text-center">[${title.toUpperCase().replace(" ", "_")}]</div>
            <div class="text-green-300">
              ${content}
            </div>
            <div class="text-center mt-6">
              <button class="px-6 py-2 bg-green-500/20 border border-green-500/40 text-green-400 rounded hover:bg-green-500/30 transition-all duration-300 font-mono text-sm close-modal">
                [CLOSE]
              </button>
            </div>
          </div>
        </div>
      `;
      document.body.appendChild(modal);
      const closeBtn = modal.querySelector(".close-modal");
      const closeModal = () => {
        if (modal.parentNode) {
          modal.parentNode.removeChild(modal);
        }
      };
      if (closeBtn) {
        closeBtn.addEventListener("click", closeModal);
      }
      modal.addEventListener("click", e => {
        if (e.target === modal) closeModal();
      });
    }
  });
</script>
