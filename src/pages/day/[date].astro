---
// Dynamic route for date-specific dashboard
// Accessed as /day/2026-02-19

import Base from "@layouts/Base.astro";
import {
  PAGE_METADATA,
  MIN_DATA_DATE_REAL,
  MIN_DATA_DATE_DUMMY,
} from "@src/consts";
import SectionLayout from "@components/SectionLayout.astro";
import DayMetricsGrid from "@components/DayMetricsGrid.astro";
import DayComparison from "@components/DayComparison.astro";
import InsightsPanel from "@components/InsightsPanel.astro";
import MoveMinutesChart from "@components/MoveMinutesChart.astro";
import HeartRateZones from "@components/HeartRateZones.astro";
import HeatmapGrid from "@components/HeatmapGrid.astro";
import ActivityDashboard from "@components/ActivityDashboard.astro";
import HevyWorkoutCount from "@components/HevyWorkoutCount.astro";
import DatePicker from "@components/DatePicker.astro";

import {
  getDataForDate,
  getComparisons,
  calculateStreaks,
  isTestDataMode,
  getTestModeSnapshot,
  getMinDataDate,
} from "@services/dataAggregationService";
import {
  fetchDistanceData,
  processDistanceData,
} from "@services/stravaService";
import { generateInsights, getPersonalRecords } from "@utils/statsUtils";
import { loadAllDataFromJSON } from "@lib/jsonLoader";
import { Flame, Zap, Dumbbell } from "lucide-astro";

// Generate static paths from minimum data date to today
// Uses REAL data date for production builds (dummy data is only for development)
export async function getStaticPaths() {
  const paths: Array<{ params: { date: string } }> = [];
  const today = new globalThis.Date();

  // In production builds, always use real data date range
  // Dummy data is only used during development with USE_DUMMY_HEALTH_DATA=true
  const isDummyMode =
    String(import.meta.env.USE_DUMMY_HEALTH_DATA || "").toLowerCase() ===
    "true";
  const minDateStr = isDummyMode ? MIN_DATA_DATE_DUMMY : MIN_DATA_DATE_REAL;
  const minDate = new globalThis.Date(minDateStr);

  // Generate paths from min data date to today
  let currentDate = new globalThis.Date(minDate);
  while (currentDate <= today) {
    const dateStr = `${currentDate.getFullYear()}-${String(currentDate.getMonth() + 1).padStart(2, "0")}-${String(currentDate.getDate()).padStart(2, "0")}`;
    paths.push({ params: { date: dateStr } });
    currentDate.setDate(currentDate.getDate() + 1);
  }

  return paths;
}

// Get date from path parameter
const { date } = Astro.params;
const selectedDate = date || "";

// Validate date format
if (!/^\d{4}-\d{2}-\d{2}$/.test(selectedDate)) {
  return Astro.redirect("/");
}

console.log(`[day/[date]] Loading dashboard for date: ${selectedDate}`);

// Parse date string properly to avoid timezone issues
const [year, month, day] = selectedDate.split("-").map(Number);
const selectedDateObj = new globalThis.Date(year, month - 1, day);

// Calculate previous and next day dates
const prevDay = new globalThis.Date(selectedDateObj);
prevDay.setDate(prevDay.getDate() - 1);
const prevDayStr = `${prevDay.getFullYear()}-${String(prevDay.getMonth() + 1).padStart(2, "0")}-${String(prevDay.getDate()).padStart(2, "0")}`;

const nextDay = new globalThis.Date(selectedDateObj);
nextDay.setDate(nextDay.getDate() + 1);
const nextDayStr = `${nextDay.getFullYear()}-${String(nextDay.getMonth() + 1).padStart(2, "0")}-${String(nextDay.getDate()).padStart(2, "0")}`;

// Format date for display
const displayDate = new Intl.DateTimeFormat("en-US", {
  weekday: "short",
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: "UTC",
}).format(new globalThis.Date(globalThis.Date.UTC(year, month - 1, day, 12)));

// Check if selected date is today
const today = new globalThis.Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, "0")}-${String(today.getDate()).padStart(2, "0")}`;
const isToday = selectedDate === todayStr;
const isNextDayFuture = nextDayStr > todayStr;
// Check if we can go back (not at minimum data date)
const minDataDate = getMinDataDate();
const isPrevDayBeforeMinDate = prevDayStr < minDataDate;

// Fetch all data for selected date
const dayData = await getDataForDate(selectedDate);
const comparisons = await getComparisons(selectedDate);
const streaks = await calculateStreaks(selectedDate);
const testMode = isTestDataMode();
const testSnapshot = testMode ? await getTestModeSnapshot() : null;

// Fetch data for insights generation
// CRITICAL: Use JSON loader to avoid API calls during build (90 pages × 3 APIs = 270 calls!)
let stepsData = {};
let allActivities: any[] = [];
let allWorkouts: any[] = [];

if (testMode && testSnapshot) {
  stepsData = testSnapshot.stepsData;
  allActivities = testSnapshot.activities;
  allWorkouts = testSnapshot.workouts;
} else {
  // Load from pre-generated JSON files (no API calls!)
  const jsonData = await loadAllDataFromJSON();
  if (jsonData) {
    stepsData = jsonData.health.steps || {};
    allActivities = jsonData.strava.activities || [];
    allWorkouts = jsonData.hevy.workouts || [];
    console.log(`[day/[date]] ✅ Loaded data from JSON (no API calls)`);
  } else {
    console.warn(`[day/[date]] ⚠️ JSON files not found, using empty data`);
  }
}

const personalRecords = getPersonalRecords(
  stepsData,
  allActivities,
  allWorkouts,
);
const insights = generateInsights(
  dayData,
  comparisons,
  streaks,
  personalRecords,
);

// Pre-calculate activity data
const findLastActivityByType = (type: string) => {
  const activity = allActivities.find(a => {
    const activityType = a.type || a.sport_type || "";
    return (
      activityType.toLowerCase() === type.toLowerCase() ||
      a.name.toLowerCase().includes(type.toLowerCase())
    );
  });

  if (!activity) return null;

  const activityDate = new globalThis.Date(activity.start_date);
  const newYorkDate = new globalThis.Date(
    activityDate.toLocaleString("en-US", { timeZone: "America/New_York" }),
  );

  return { date: newYorkDate, activity };
};

const activityData = {
  run: findLastActivityByType("run"),
  ride: findLastActivityByType("ride"),
  swim: findLastActivityByType("swim"),
  walk: findLastActivityByType("walk"),
};

// Fetch 365-day heatmap data
const distanceMap =
  testMode && testSnapshot
    ? testSnapshot.distanceMap
    : await fetchDistanceData();
const distanceData = processDistanceData(distanceMap);
const positiveDistances = distanceData
  .map(data => data[1])
  .filter(value => value > 0);
const minDistance =
  positiveDistances.length > 0 ? Math.min(...positiveDistances) : 0;
const maxDistance =
  positiveDistances.length > 0 ? Math.max(...positiveDistances) : 1;

// Fetch move minutes and heart rate from JSON (no API calls!)
let moveMinutesData = {};
let heartRateData = {};

if (testMode && testSnapshot) {
  moveMinutesData = testSnapshot.moveMinutesData;
  heartRateData = testSnapshot.heartRateData;
} else {
  const healthJson = await loadAllDataFromJSON();
  if (healthJson) {
    moveMinutesData = healthJson.health.moveMinutes || {};
    heartRateData = healthJson.health.heartRate || {};
  }
}

// Get Hevy workout count from JSON (no API call!)
let workoutCount = 0;
if (testMode && testSnapshot) {
  workoutCount = testSnapshot.workoutCount;
} else {
  const hevyJson = await loadAllDataFromJSON();
  if (hevyJson && hevyJson.hevy.workouts) {
    workoutCount = hevyJson.hevy.workouts.length;
  }
}

// Generate terminal command with date
const terminalCommand = `./view_metrics.sh ${selectedDate}`;

// Generate system message with API status
const hasSteps = dayData.steps.count > 0;
const hasActivities = dayData.activities.length > 0;
const hasWorkouts = dayData.workouts.length > 0;
const modeLabel = testMode ? "TEST" : "LIVE";
const systemMessage = `${selectedDate} | Fit: ${hasSteps ? "✓" : "○"} | Strava: ${hasActivities ? "✓" : "○"} | Hevy: ${hasWorkouts ? "✓" : "○"}`;
---

<Base
  title={PAGE_METADATA.index.title}
  description={PAGE_METADATA.index.description}
  keywords={PAGE_METADATA.index.keywords}
  windowTitle="FITNESS_DASHBOARD"
  terminalCommand={terminalCommand}
  systemMessage={systemMessage}
>
  <!-- Date Navigator -->
  <div class="date-navigator">
    <a
      href={isPrevDayBeforeMinDate ? "#" : `/day/${prevDayStr}`}
      class={`nav-arrow ${isPrevDayBeforeMinDate ? "disabled" : ""}`}
      title="Previous day"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
    </a>

    <div class="date-display">
      <div class="date-text">{displayDate}</div>
      <div class="date-picker-container">
        <DatePicker
          selectedDate={selectedDate}
          minDate={minDataDate}
          label=""
        />
      </div>
      {
        !isToday && (
          <a href="/" class="today-btn">
            [TODAY]
          </a>
        )
      }
    </div>

    <a
      href={isNextDayFuture ? "#" : `/day/${nextDayStr}`}
      class={`nav-arrow ${isNextDayFuture ? "disabled" : ""}`}
      title="Next day"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <!-- Same content as index.astro -->
  <SectionLayout title="[DAILY_METRICS]">
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
    >
    </div>
    <DayMetricsGrid dayData={dayData} />
  </SectionLayout>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <SectionLayout title="[INSIGHTS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-yellow-400 rounded-full animate-pulse"
      >
      </div>
      <InsightsPanel insights={insights} />
    </SectionLayout>

    <SectionLayout title="[COMPARISONS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"
      >
      </div>
      <DayComparison comparisons={comparisons} />
    </SectionLayout>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <SectionLayout title="[MOVE_MINUTES]" rightHeaderText="[LAST_7_DAYS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-purple-400 rounded-full animate-pulse"
      >
      </div>
      <MoveMinutesChart moveMinutesData={moveMinutesData} days={7} />
    </SectionLayout>

    <SectionLayout title="[HEART_RATE_ZONES]" rightHeaderText="[LAST_7_DAYS]">
      <div
        slot="headerElements"
        class="w-2 h-2 bg-red-400 rounded-full animate-pulse"
      >
      </div>
      <HeartRateZones heartRateData={heartRateData} daysToShow={7} />
    </SectionLayout>
  </div>

  <SectionLayout title="[ACTIVITY_STATUS]" rightHeaderText="[DAYS_SINCE_LAST]">
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
    >
    </div>
    <ActivityDashboard activityData={activityData} />
  </SectionLayout>

  <SectionLayout title="[HEVY_WORKOUT]" rightHeaderText="[TOTAL_WORKOUT_COUNT]">
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
    >
    </div>
    <HevyWorkoutCount workoutCount={workoutCount} />
  </SectionLayout>

  <SectionLayout
    title="[ANNUAL_OVERVIEW]"
    rightHeaderText="[365_DAY_ACTIVITY_MAP]"
  >
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
    >
    </div>
    <div class="heatmap-container">
      <div class="heatmap-wrapper">
        <div class="heatmap-info mb-4">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-xs">
            <div class="info-block">
              <span class="text-green-400/60">DATA_RANGE:</span>
              <span class="text-green-300 ml-2">365 DAYS</span>
            </div>
            <div class="info-block">
              <span class="text-green-400/60">MIN_ACTIVITY:</span>
              <span class="text-green-300 ml-2"
                >{minDistance.toFixed(1)} KM</span
              >
            </div>
            <div class="info-block">
              <span class="text-green-400/60">MAX_ACTIVITY:</span>
              <span class="text-green-300 ml-2"
                >{maxDistance.toFixed(1)} KM</span
              >
            </div>
          </div>
        </div>

        <HeatmapGrid
          distanceData={distanceData}
          minDistance={minDistance}
          maxDistance={maxDistance}
        />

        <div class="heatmap-footer mt-4">
          <div class="flex justify-between items-center text-xs">
            <div class="flex items-center space-x-4">
              <span class="text-green-400/60">NEURAL_ACTIVITY_TRACKING</span>
              <div class="flex items-center space-x-1">
                <div class="w-1 h-1 bg-green-500 rounded-full animate-pulse">
                </div>
                <span class="text-green-500">ONLINE</span>
              </div>
            </div>

            <a
              href="https://www.strava.com/athletes/47698767"
              target="_blank"
              rel="noopener noreferrer"
              class="strava-link-button group"
            >
              <span
                class="text-green-300 hover:text-green-100 transition-colors duration-300 font-mono text-xs flex items-center space-x-2"
              >
                <span>[VERIFY_ON_STRAVA]</span>
                <svg
                  class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </SectionLayout>

  <SectionLayout title="[ACTIVE_STREAKS]">
    <div class="streaks-grid">
      {
        streaks.steps.current > 0 && (
          <div class="streak-card">
            <span class="streak-icon">
              <Flame size={16} />
            </span>
            <div class="streak-info">
              <div class="streak-value">{streaks.steps.current} days</div>
              <div class="streak-label">Step Goal Streak</div>
              <div class="streak-record">
                Best: {streaks.steps.longest} days
              </div>
            </div>
          </div>
        )
      }
      {
        streaks.activities.current > 0 && (
          <div class="streak-card">
            <span class="streak-icon">
              <Zap size={16} />
            </span>
            <div class="streak-info">
              <div class="streak-value">{streaks.activities.current} days</div>
              <div class="streak-label">Activity Streak</div>
              <div class="streak-record">
                Best: {streaks.activities.longest} days
              </div>
            </div>
          </div>
        )
      }
      {
        streaks.workouts.current > 0 && (
          <div class="streak-card">
            <span class="streak-icon">
              <Dumbbell size={16} />
            </span>
            <div class="streak-info">
              <div class="streak-value">{streaks.workouts.current} days</div>
              <div class="streak-label">Workout Streak</div>
              <div class="streak-record">
                Best: {streaks.workouts.longest} days
              </div>
            </div>
          </div>
        )
      }
    </div>
  </SectionLayout>
</Base>

<style>
  /* Copy all styles from index.astro */
  .heatmap-container {
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 20, 0, 0.6) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 8px;
    padding: 20px;
    box-shadow:
      0 0 20px rgba(0, 255, 0, 0.2),
      inset 0 0 20px rgba(0, 255, 0, 0.05);
    position: relative;
    overflow: hidden;
  }

  .heatmap-wrapper {
    position: relative;
    z-index: 2;
  }

  .heatmap-info,
  .heatmap-footer {
    font-family: "Courier New", monospace;
  }

  .info-block {
    padding: 4px 0;
  }

  .strava-link-button {
    position: relative;
    padding: 6px 12px;
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 4px;
    background: rgba(0, 255, 0, 0.05);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .strava-link-button:hover {
    background: rgba(0, 255, 0, 0.1);
    border-color: rgba(0, 255, 0, 0.6);
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.3);
    transform: translateY(-1px);
  }

  .streaks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }

  .streak-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 20, 0, 0.5) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 6px;
    transition: all 0.3s ease;
  }

  .streak-card:hover {
    border-color: rgba(0, 255, 0, 0.5);
    box-shadow: 0 0 15px rgba(0, 255, 0, 0.2);
    transform: translateY(-2px);
  }

  .streak-icon {
    font-size: 2rem;
    animation: pulse 2s ease-in-out infinite;
  }

  .streak-info {
    flex: 1;
    font-family: "Courier New", monospace;
  }

  .streak-value {
    font-size: 1.5rem;
    font-weight: bold;
    color: #00ff00;
    margin-bottom: 0.25rem;
  }

  .streak-label {
    font-size: 0.75rem;
    color: rgba(0, 255, 0, 0.7);
    margin-bottom: 0.25rem;
  }

  .streak-record {
    font-size: 0.65rem;
    color: rgba(0, 255, 0, 0.5);
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 1;
    }
  }

  .date-navigator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 1.5rem 1rem;
    margin-bottom: 2rem;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 20, 0, 0.6) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 8px;
    font-family: "Courier New", monospace;
  }

  .nav-arrow {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 6px;
    color: #00ff00;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .nav-arrow:hover {
    background: rgba(0, 255, 0, 0.15);
    border-color: rgba(0, 255, 0, 0.6);
    box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
    transform: scale(1.1);
  }

  .nav-arrow.disabled,
  .nav-arrow.disabled:hover {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
    transform: none;
    box-shadow: none;
  }

  .nav-arrow svg {
    width: 20px;
    height: 20px;
  }

  .date-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 280px;
  }

  .date-picker-container {
    width: 100%;
    max-width: 260px;
  }

  .date-text {
    font-size: 1.25rem;
    font-weight: bold;
    color: #00ff00;
    text-align: center;
    letter-spacing: 0.05em;
    text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
  }

  .today-btn {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 255, 0, 0.1);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 4px;
    color: rgba(0, 255, 0, 0.8);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .today-btn:hover {
    background: rgba(0, 255, 0, 0.2);
    border-color: rgba(0, 255, 0, 0.5);
    color: #00ff00;
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
  }

  @media (max-width: 768px) {
    .heatmap-container {
      padding: 12px;
    }

    .streaks-grid {
      grid-template-columns: 1fr;
    }

    .streak-icon {
      font-size: 1.5rem;
    }

    .streak-value {
      font-size: 1.25rem;
    }

    .date-navigator {
      gap: 1rem;
      padding: 1rem;
    }

    .nav-arrow {
      width: 36px;
      height: 36px;
    }

    .date-display {
      min-width: 200px;
    }

    .date-text {
      font-size: 1rem;
    }
  }
</style>
