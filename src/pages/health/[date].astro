---
// Dynamic route for date-specific health dashboard
// Accessed as /health/2026-02-19

// Generate static paths for the last 90 days
export async function getStaticPaths() {
  const paths: Array<{ params: { date: string } }> = [];
  const today = new globalThis.Date();

  // Generate paths for last 90 days
  for (let i = 0; i < 90; i++) {
    const date = new globalThis.Date(today);
    date.setDate(date.getDate() - i);
    const dateStr = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
    paths.push({ params: { date: dateStr } });
  }

  return paths;
}

import Layout from "@/layouts/Base.astro";
import SectionLayout from "@/components/SectionLayout.astro";
import StepsCounter from "@/components/StepsCounter.astro";
import HealthHeatmap from "@/components/HealthHeatmap.astro";
import SleepTracker from "@/components/SleepTracker.astro";
import HeartRateZones from "@/components/HeartRateZones.astro";
import type {
  StepsData,
  SleepData,
  HeartRateData,
} from "@/services/googleFitService";
import { readFile } from "node:fs/promises";
import { resolve } from "node:path";

// Get date from path parameter
const { date } = Astro.params;
const dateToUse = date || "";

// Validate date format
if (!/^\d{4}-\d{2}-\d{2}$/.test(dateToUse)) {
  return Astro.redirect("/health");
}

console.log(`[health/[date]] Loading health data for date: ${dateToUse}`);

// Parse date string properly
const [year, month, day] = dateToUse.split("-").map(Number);
const selectedDateObj = new globalThis.Date(year, month - 1, day);

// Calculate previous and next day dates
const prevDay = new globalThis.Date(selectedDateObj);
prevDay.setDate(prevDay.getDate() - 1);
const prevDayStr = `${prevDay.getFullYear()}-${String(prevDay.getMonth() + 1).padStart(2, "0")}-${String(prevDay.getDate()).padStart(2, "0")}`;

const nextDay = new globalThis.Date(selectedDateObj);
nextDay.setDate(nextDay.getDate() + 1);
const nextDayStr = `${nextDay.getFullYear()}-${String(nextDay.getMonth() + 1).padStart(2, "0")}-${String(nextDay.getDate()).padStart(2, "0")}`;

// Format date for display
const displayDate = new Intl.DateTimeFormat("en-US", {
  weekday: "short",
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: "UTC",
}).format(new globalThis.Date(globalThis.Date.UTC(year, month - 1, day, 12)));

// Check if selected date is today
const today = new globalThis.Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, "0")}-${String(today.getDate()).padStart(2, "0")}`;
const isToday = dateToUse === todayStr;
const isNextDayFuture = nextDayStr > todayStr;

// Load cached health data from JSON file (no API call during build!)
let healthData: {
  steps: StepsData;
  sleep: SleepData;
  heartRate: HeartRateData;
  lastUpdated: string;
  source: string;
} = {
  steps: {},
  sleep: {},
  heartRate: {},
  lastUpdated: new globalThis.Date().toISOString(),
  source: "Google Fit",
};

try {
  const isTestMode =
    String(import.meta.env.USE_DUMMY_HEALTH_DATA || "").toLowerCase() ===
    "true";
  const sourceFile = isTestMode
    ? String(import.meta.env.HEALTH_DATA_FILE || "health-data-dummy.json")
    : "health-data.json";
  const filePath = resolve(process.cwd(), "public", sourceFile);
  const fileContents = await readFile(filePath, "utf-8");
  healthData = await JSON.parse(fileContents);
} catch (error) {
  console.warn("Could not load health data:", error);
}

// Get data for selected date
const dayData = healthData.steps[dateToUse] || {
  steps: 0,
  distance: 0,
  calories: 0,
};

const daySleepData = healthData.sleep[dateToUse] || null;
const dayHeartRateData = healthData.heartRate[dateToUse] || null;

// Calculate total days with data
const totalStepDays = Object.keys(healthData.steps).filter(
  date => healthData.steps[date].steps > 0,
).length;
const totalSleepNights = Object.keys(healthData.sleep).length;
const totalHRDays = Object.keys(healthData.heartRate).length;

// Format last updated
const lastUpdated = new globalThis.Date(healthData.lastUpdated);
const lastUpdatedStr = lastUpdated.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
  hour: "numeric",
  minute: "2-digit",
});
---

<Layout
  title="Health Matrix | Fitness Tracker"
  windowTitle="HEALTH_MONITOR"
  terminalCommand={`./run_health_scan.exe ${dateToUse}`}
  systemMessage={`${dateToUse} | Google Fit: ${dayData.steps > 0 ? "✓" : "○"} | Sleep: ${daySleepData ? "✓" : "○"} | HR: ${dayHeartRateData ? "✓" : "○"}`}
>
  <!-- Date Navigator -->
  <div class="date-navigator">
    <a href={`/health/${prevDayStr}`} class="nav-arrow" title="Previous day">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
    </a>

    <div class="date-display">
      <div class="date-text">{displayDate}</div>
      {!isToday && <a href="/health" class="today-btn">[TODAY]</a>}
    </div>

    <a
      href={isNextDayFuture ? "#" : `/health/${nextDayStr}`}
      class={`nav-arrow ${isNextDayFuture ? "disabled" : ""}`}
      title="Next day"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>

  <!-- Daily Steps Counter -->
  <SectionLayout title="[DAILY_METRICS]" rightHeaderText={`[${dateToUse}]`}>
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
    >
    </div>
    <StepsCounter
      steps={dayData.steps}
      distance={dayData.distance}
      calories={dayData.calories}
    />
  </SectionLayout>

  <!-- Steps Heatmap (365 days) -->
  <SectionLayout
    title="[ACTIVITY_HEATMAP]"
    rightHeaderText={`[${totalStepDays}_ACTIVE_DAYS]`}
  >
    <div
      slot="headerElements"
      class="w-2 h-2 bg-green-500 rounded-full animate-pulse"
    >
    </div>
    <HealthHeatmap stepsData={healthData.steps} />
  </SectionLayout>

  <!-- Sleep Tracker -->
  <SectionLayout
    title="[SLEEP_ANALYSIS]"
    rightHeaderText={`[${totalSleepNights}_NIGHTS_TRACKED]`}
  >
    <div
      slot="headerElements"
      class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"
    >
    </div>
    {
      totalSleepNights > 0 ? (
        <SleepTracker sleepData={healthData.sleep} daysToShow={14} />
      ) : (
        <div class="no-data-message">
          <div class="bg-black/60 border border-green-500/30 rounded-lg p-8 text-center">
            <div class="text-green-400/60 font-mono text-sm mb-2">
              NO_SLEEP_DATA_AVAILABLE
            </div>
            <div class="text-green-300/80 font-mono text-xs">
              Sleep tracking will appear here once Google Fit syncs your Zepp
              data.
            </div>
            <div class="text-green-400/60 font-mono text-xs mt-4">
              To sync: Open Zepp app → Profile → Third-party access → Google Fit
              → Sync
            </div>
          </div>
        </div>
      )
    }
  </SectionLayout>

  <!-- Heart Rate Zones -->
  <SectionLayout
    title="[HEART_RATE_ZONES]"
    rightHeaderText={`[${totalHRDays}_DAYS_MONITORED]`}
  >
    <div
      slot="headerElements"
      class="w-2 h-2 bg-red-400 rounded-full animate-pulse"
    >
    </div>
    {
      totalHRDays > 0 ? (
        <HeartRateZones heartRateData={healthData.heartRate} daysToShow={14} />
      ) : (
        <div class="no-data-message">
          <div class="bg-black/60 border border-green-500/30 rounded-lg p-8 text-center">
            <div class="text-green-400/60 font-mono text-sm mb-2">
              NO_HEART_RATE_DATA_AVAILABLE
            </div>
            <div class="text-green-300/80 font-mono text-xs">
              Heart rate monitoring will appear here once Google Fit syncs your
              Zepp data.
            </div>
            <div class="text-green-400/60 font-mono text-xs mt-4">
              To sync: Open Zepp app → Profile → Third-party access → Google Fit
              → Sync
            </div>
          </div>
        </div>
      )
    }
  </SectionLayout>

  <!-- Data Source Info -->
  <SectionLayout title="[DATA_SOURCE]" rightHeaderText="[SYNC_STATUS]">
    <div
      class="bg-black/60 border border-green-500/30 rounded-lg p-6 font-mono"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div>
          <span class="text-green-400/60">SOURCE:</span>
          <span class="text-green-300 ml-2">{healthData.source}</span>
        </div>
        <div>
          <span class="text-green-400/60">LAST_UPDATED:</span>
          <span class="text-green-300 ml-2">{lastUpdatedStr}</span>
        </div>
      </div>
    </div>
  </SectionLayout>
</Layout>

<style>
  .no-data-message {
    animation: fadeIn 0.5s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Date Navigator Styles */
  .date-navigator {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 20, 0, 0.7) 100%
    );
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 8px;
    box-shadow: 0 0 20px rgba(0, 255, 0, 0.15);
    font-family: "Courier New", monospace;
  }

  .nav-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 6px;
    color: #00ff00;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .nav-arrow:hover:not(.disabled) {
    background: rgba(0, 255, 0, 0.15);
    border-color: rgba(0, 255, 0, 0.6);
    box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
    transform: scale(1.1);
  }

  .nav-arrow.disabled {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }

  .nav-arrow svg {
    width: 20px;
    height: 20px;
  }

  .date-display {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 220px;
  }

  .date-text {
    font-size: 1.25rem;
    font-weight: bold;
    color: #00ff00;
    text-align: center;
    letter-spacing: 0.05em;
    text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
  }

  .today-btn {
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 255, 0, 0.1);
    border: 1px solid rgba(0, 255, 0, 0.3);
    border-radius: 4px;
    color: rgba(0, 255, 0, 0.8);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .today-btn:hover {
    background: rgba(0, 255, 0, 0.2);
    border-color: rgba(0, 255, 0, 0.5);
    color: #00ff00;
    box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
  }

  @media (max-width: 480px) {
    .date-navigator {
      gap: 1rem;
      padding: 0.75rem;
    }

    .nav-arrow {
      width: 36px;
      height: 36px;
    }

    .date-display {
      min-width: 180px;
    }

    .date-text {
      font-size: 1rem;
    }
  }
</style>
